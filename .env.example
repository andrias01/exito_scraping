# ────────────────────────────────────────────────────────────
# Monitor Precios Éxito Colombia - Variables de entorno
# Copia este archivo como .env y completa los valores
# ────────────────────────────────────────────────────────────

# ── Base de datos ────────────────────────────────────────────
DATABASE_URL=sqlite:///./database/monitor.db

# ── API FastAPI ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ── Scraper Playwright ────────────────────────────────────────
SCRAPER_TIMEOUT=30000
SCRAPER_RETRIES=3
SCRAPER_RETRY_DELAY=5
SCRAPER_HEADLESS=true
SCRAPER_SLOW_MO=0

# ── Monitoreo ─────────────────────────────────────────────────
DEFAULT_FREQUENCY_MINUTES=60
MAX_RETRIES=3

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── SMTP (Gmail u otro proveedor) ─────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# ── Discord ───────────────────────────────────────────────────
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
